{
	"name": "novakit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.24.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint:ox": "oxlint .",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test --pass-with-no-tests",
		"typecheck": "tsc --noEmit",
		"precommit": "lint-staged && pnpm run lint:ox && pnpm run format:check && pnpm run lint && pnpm run check && pnpm run typecheck && pnpm run test && pnpm run test:e2e",
		"prepare": "svelte-kit sync && husky || husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"studio": "sanity dev",
		"benchmark": "node scripts/benchmark.js",
		"capture:dataset": "node scripts/capture-dataset.js",
		"capture:video": "node scripts/capture-dataset.js --video-only",
		"replay:ensemble": "tsx scripts/replay-ensemble.ts",
		"replay:ensemble:impute-video": "tsx scripts/replay-ensemble.ts --impute-video"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sanity/cli": "^6.2.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^25.0.9",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"oxlint": "^1.68.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"sanity": "^5.17.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^7.3.1",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@sanity/client": "^7.20.0",
		"@sanity/image-url": "^2.0.3",
		"exifr": "^7.1.3",
		"face-api.js": "^0.22.2",
		"jspdf": "^4.2.1",
		"mediainfo.js": "^0.3.7"
	},
	"pnpm": {
		"overrides": {
			"cookie": "^0.7.2",
			"js-yaml": "^3.14.2",
			"node-fetch": "^2.7.0",
			"uuid": "^11.1.1"
		}
	}
}
